{
  "buildCommand": "echo 'Static site - no build'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/slides/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/ai-markets-deck.pptx",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.openxmlformats-officedocument.presentationml.presentation" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"ai-markets-deck.pptx\"" }
      ]
    }
  ]
}
